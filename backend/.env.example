PORT=8080
APP_ENV=development

# Application DSN (used by the Go server; typically requires SSL)
POSTGRES_DSN=postgres://user:password@host:5432/dbname?sslmode=require

# Migration DSN (used by dbmate and jet codegen; direct connection, SSL optional)
# Can differ from POSTGRES_DSN if the migration tool needs a direct connection.
POSTGRES_MIGRATION_URL=postgresql://user:password@host:5432/dbname?sslmode=disable

MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net
MONGO_DB=personal_dashboard

FIREBASE_CREDENTIALS='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}'

# Firebase UID of the single app user.
# Required: used by both the LINE webhook and (when MCP_AUTH_TOKEN is set) the MCP server.
# To find your UID: sign in to the web app once; it is the user_id stored in the users table.
MCP_USER_FIREBASE_UID=

# Static bearer token for the /mcp endpoint. Generate with: openssl rand -hex 32
# Leave empty to disable the /mcp endpoint.
MCP_AUTH_TOKEN=

# LINE Messaging API credentials (required — used by POST /api/v1/line/webhook).
# Channel ID and Secret come from the LINE Developers console (Basic settings).
# Channel Access Token comes from Messaging API > Channel access token (long-lived).
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

GEMINI_API_KEY=
GEMINI_MODEL=
GEMINI_TTS_MODEL=
